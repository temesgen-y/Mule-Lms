# API base URL (backend)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Supabase (required for auth and data)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# OAuth / OpenID Connect (Microsoft SSO)
# NEXT_PUBLIC_OIDC_CLIENT_ID=
# NEXT_PUBLIC_OIDC_AUTHORITY=https://login.microsoftonline.com/{tenant}/v2.0
# NEXT_PUBLIC_OIDC_REDIRECT_URI=http://localhost:3001/auth/callback
