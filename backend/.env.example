# Server
PORT=3000

# Database (optional until you add TypeORM/Prisma)
# DATABASE_URL=postgresql://user:password@localhost:5432/lms

# Redis (optional until you need cache/rate limit)
# REDIS_URL=redis://localhost:6379

# JWT (required for auth module)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=15m

# OAuth / OpenID Connect (Microsoft SSO)
# OIDC_ISSUER=https://login.microsoftonline.com/{tenant}/v2.0
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:3001/auth/callback
